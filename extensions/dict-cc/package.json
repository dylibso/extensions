{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "dict-cc",
  "title": "dict.cc",
  "description": "Simple translation using dict.cc",
  "icon": "icon.png",
  "author": "natterstefan",
  "contributors": [
    "YourMCGeek"
  ],
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "translate",
      "title": "Translate",
      "subtitle": "Dict.cc",
      "description": "Translates a given term from one into another language.",
      "mode": "view"
    },
    {
      "name": "translate-from-clipboard",
      "title": "Translate from Clipboard",
      "subtitle": "Dict.cc",
      "description": "Translates a given term (from clipboard) from one into another language.",
      "mode": "view"
    },
    {
      "name": "translate-from-selection",
      "title": "Translate from Selection",
      "subtitle": "Dict.cc",
      "description": "Translates a given term (from selection) from one into another language.",
      "mode": "view"
    }
  ],
